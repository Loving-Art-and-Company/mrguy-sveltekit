{
  "name": "mrguy-detailing",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:preflight": "bash scripts/vercel-preflight.sh",
    "ops:bookings": "node scripts/ops/bookings.mjs",
    "ops:smoke": "node scripts/ops/smoke.mjs",
    "ops:inquiries": "node scripts/ops/inquiries.mjs",
    "ops:analytics": "node scripts/ops/analytics.mjs",
    "ops:seo": "node scripts/ops/seo.mjs",
    "ops:digest": "node scripts/mrguy-ops-digest.mjs",
    "ops:daily": "bash scripts/run-ops-daily.sh",
    "ops:schedule:install": "bash scripts/ops/install-daily-launchd.sh",
    "smoke:domains": "node scripts/smoke-canonical-host.mjs",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:prod": "bash scripts/run-prod-e2e.sh",
    "test:prod:headed": "HEADED=1 bash scripts/run-prod-e2e.sh",
    "test": "NODE_OPTIONS=\"--localstorage-file=/tmp/mrguy-vitest-localstorage\" vitest run",
    "test:watch": "NODE_OPTIONS=\"--localstorage-file=/tmp/mrguy-vitest-localstorage\" vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:booking": "playwright test booking.spec.ts",
    "test:e2e:prod": "PLAYWRIGHT_SKIP_WEBSERVER=1 BASE_URL=https://mrguydetail.com playwright test",
    "test:e2e:prod:headed": "PLAYWRIGHT_SKIP_WEBSERVER=1 BASE_URL=https://mrguydetail.com playwright test --headed",
    "test:booking:prod": "PLAYWRIGHT_SKIP_WEBSERVER=1 BASE_URL=https://mrguydetail.com playwright test e2e/booking.spec.ts",
    "test:booking:prod:headed": "PLAYWRIGHT_SKIP_WEBSERVER=1 BASE_URL=https://mrguydetail.com playwright test e2e/booking.spec.ts --headed",
    "test:booking:prod:smoke": "PLAYWRIGHT_SKIP_WEBSERVER=1 BASE_URL=https://mrguydetail.com BOOKING_LIMIT=2 playwright test e2e/booking.spec.ts",
    "test:booking:prod:smoke:headed": "PLAYWRIGHT_SKIP_WEBSERVER=1 BASE_URL=https://mrguydetail.com BOOKING_LIMIT=2 playwright test e2e/booking.spec.ts --headed",
    "test:reschedule:prod": "PLAYWRIGHT_SKIP_WEBSERVER=1 BASE_URL=https://mrguydetail.com playwright test e2e/reschedule.spec.ts",
    "test:reschedule:prod:headed": "PLAYWRIGHT_SKIP_WEBSERVER=1 BASE_URL=https://mrguydetail.com playwright test e2e/reschedule.spec.ts --headed",
    "test:ralph": "npx tsx e2e/ralph-loop.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@sveltejs/adapter-vercel": "^5.0.0",
    "@sveltejs/kit": "^2.50.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/bcryptjs": "^2.4.6",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^27.4.0",
    "playwright": "^1.58.0",
    "svelte": "^5.47.1",
    "svelte-check": "^4.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@sentry/sveltekit": "^10.37.0",
    "@stripe/stripe-js": "^4.10.0",
    "@upstash/redis": "^1.36.2",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-svelte": "^0.562.0",
    "postgres": "^3.4.8",
    "posthog-js": "^1.336.4",
    "stripe": "^17.7.0",
    "zod": "^4.3.5"
  },
  "overrides": {
    "cookie": "^1.1.1"
  }
}
