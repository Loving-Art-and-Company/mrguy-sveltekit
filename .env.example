# Database
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# App
PUBLIC_BASE_URL=http://localhost:5173

# Promo (set to 'false' to disable the 25% first-time client promo)
PROMO_ENABLED=true

# Analytics (PostHog)
PUBLIC_POSTHOG_KEY=phc_your_public_key
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
PUBLIC_POSTHOG_SESSION_RECORDING=false

# Sentry Error Tracking
PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Google OAuth (Drive, Docs, Calendar, Gmail, GA4, Search Console)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
GOOGLE_SHARED_DRIVE_ID=your-shared-drive-id
GOOGLE_ANALYTICS_PROPERTY_ID=123456789
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://mrguydetail.com/

# Optional PostHog ops reporting
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# Lead sink (recommended: brand-dedicated webhook that appends to a locked-down Google Sheet)
LEAD_SINK_WEBHOOK_URL=
LEAD_SINK_WEBHOOK_SECRET=
LEAD_SINK_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Ops agent
MRGUY_OPS_ALERT_TO=you@example.com
MRGUY_BUSINESS_EMAIL=info@mrguymobiledetail.com
MRGUY_MONITOR_EMAIL=info@lovingartandcompany.com
SEND_ALERTS=0
